---
import RssIconButton from "@/components/RssIconButton.astro";
import { useTranslatedPath, type Lang } from "@/scripts/i18n";
import { sectionMap } from "@/scripts/section";
import { Icon } from "astro-icon/components";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const translatePath = useTranslatedPath(lang);

const diff = new Date().getTime() - new Date("2017-08-01").getTime();
const totalYears = diff / (1000 * 60 * 60 * 24 * 365.25);
const currentYear = new Date().getFullYear();
---

<footer>
  <div class="footer-inner">
    <div class="footer-flex">
      <!-- Col 1: Brand + Social -->
      <div class="wsj-masthead">
        <div class="wsj-logo"><a href={translatePath("")}>THE PESSIMISTIC OPTIMIST.</a></div>
        <div class="wsj-author">
          {lang === "ko" && <>{totalYears.toFixed(1)}년차 Web Application Developer 웹 개발자</>}
          {lang === "en" && <>Senior Web Application Developer ({totalYears.toFixed(1)}+ years)</>}
          {lang === "ja" && <>Webアプリケーションエンジニア (経験{totalYears.toFixed(1)}年)</>}
        </div>
        <div class="social-row">
          <a href={sectionMap.linkedin.url} class="social-btn" title={sectionMap.linkedin.title}>
            <Icon name="fa6-brands:linkedin" class="social-icon" />
          </a>
          <a href={sectionMap.facebook.url} class="social-btn" title={sectionMap.facebook.title}>
            <Icon name="fa6-brands:facebook" class="social-icon" />
          </a>
          <a class="social-btn">
            <RssIconButton />
          </a>
        </div>
      </div>
      <!-- Col 2: Categories -->
      <div class="col-categories">
        <ul class="cat-list">
          <li>
            <a href={translatePath(sectionMap.politics.url)}>
              {sectionMap.politics.title}{
                lang !== "en" && (
                  <>
                    <br />
                    <span class="cat-sub">{sectionMap.politics.shorten[lang]}</span>
                  </>
                )
              }
            </a>
          </li>
          <li>
            <a href={translatePath(sectionMap.leadership.url)}>
              {sectionMap.leadership.title}{
                lang !== "en" && (
                  <>
                    <br />
                    <span class="cat-sub">{sectionMap.leadership.shorten[lang]}</span>
                  </>
                )
              }
            </a>
          </li>
          <li>
            <a href={translatePath(sectionMap.economy.url)}>
              {sectionMap.economy.title}{
                lang !== "en" && (
                  <>
                    <br />
                    <span class="cat-sub">{sectionMap.economy.shorten[lang]}</span>
                  </>
                )
              }
            </a>
          </li>
          <li>
            <a href={translatePath(sectionMap.education.url)}>
              {sectionMap.education.title}{
                lang !== "en" && (
                  <>
                    <br />
                    <span class="cat-sub">{sectionMap.education.shorten[lang]}</span>
                  </>
                )
              }
            </a>
          </li>
          <li>
            <a href={translatePath(sectionMap.engineering.url)}>
              {sectionMap.engineering.title}{
                lang !== "en" && (
                  <>
                    <br />
                    <span class="cat-sub">{sectionMap.engineering.shorten[lang]}</span>
                  </>
                )
              }
            </a>
          </li>
          <li>
            <a href={translatePath(sectionMap.opinion.url)}>
              {sectionMap.opinion.title}{
                lang !== "en" && (
                  <>
                    <br />
                    <span class="cat-sub">{sectionMap.opinion.shorten[lang]}</span>
                  </>
                )
              }
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <span class="footer-copy">© 2019-{currentYear} Aaron Ryu. All Rights Reserved.</span>
    <nav class="footer-nav">
      <a href={translatePath(sectionMap.posts.url)}>{sectionMap.posts.title}</a>
      <a href={translatePath(sectionMap.categories.url)}>{sectionMap.categories.title}</a>
      <a href={translatePath(sectionMap.hobby.url)}>{sectionMap.hobby.title}</a>
      <a href={sectionMap.about.url} target="_blank" rel="noopener noreferrer">
        {sectionMap.about.title}
      </a>
    </nav>
  </div>
</footer>

<style>
  /* (B) 블로그 타이틀과 테마버튼이 위치한 상단 헤더 */
  .wsj-masthead {
    display: flex;
    flex-direction: column;
    align-items: start;
    justify-content: center;
    position: relative;
    flex-shrink: 0;

    a {
      color: #b6bfc8;
    }
  }
  .wsj-logo {
    font-family: "Times New Roman", Times, serif;
    font-size: 1.4em;
    font-weight: 600;
    line-height: 0.9em;
    letter-spacing: -0.5px;
    text-align: start;
  }
  .wsj-author {
    font-size: 0.7em;
    font-weight: 200;
    letter-spacing: -0.5px;
    text-align: center;
    margin-top: -0.15em;
  }

  /* ───── FAKE PAGE CONTENT ───── */
  .fake-page {
    background: #f5f5f3;
    padding: 48px 32px 64px;
    text-align: center;
    color: #aaa;
    font-size: 14px;
    border-bottom: 0.5px solid #ddd;
  }

  /* ───── FOOTER ───── */
  footer {
    background: #2a2a2e;
    color: #c8c8cc;
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2em 2em 0em;
  }

  /* ── 3-column grid (desktop) ── */
  .footer-flex {
    display: flex;
    justify-content: space-between;
    gap: 2em;
    padding-bottom: 1.4em;
    border-bottom: 0.5px solid #484850;
  }

  /* ── Social ── */
  .social-row {
    display: flex;
    gap: 12px;
    margin-top: 0.3em;
  }

  .social-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 0.5px solid #484850;
    background: transparent;
    text-decoration: none;
    transition:
      border-color 0.15s,
      background 0.15s;
  }
  .social-btn:hover {
    border-color: #aaa;
    background: #383840;
  }
  .social-btn svg {
    width: 16px;
    height: 16px;
  }

  /* ── Categories ── */
  .cat-list {
    padding: 0em;
    margin: 0em;
    list-style: none;
    line-height: 1em;
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 10px;
  }
  .cat-list li {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }
  .cat-list a {
    font-size: 0.8em;
    font-weight: 400;
    color: #ddd;
    text-decoration: none;
  }
  .cat-list a:hover {
    color: #fff;
  }
  .cat-sub {
    font-size: 0.7em;
    color: #666;
  }
  a:hover .cat-sub {
    color: #ddd;
  }

  /* ── Footer bottom bar ── */
  .footer-bottom {
    max-width: 1100px;
    margin: 0 auto;
    padding: 16px 32px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 8px;
  }
  .footer-copy {
    font-size: 12px;
    color: #666;
  }
  .footer-nav {
    display: flex;
    gap: 16px;
  }
  .footer-nav a {
    font-size: 12px;
    color: #666;
    text-decoration: none;
  }
  .footer-nav a:hover {
    color: #aaa;
  }

  /* ───── MOBILE (≤ 600px) ───── */
  @media (max-width: 600px) {
    .footer-inner {
      padding: 1.4em 1.4em 0em;
    }

    .cat-list {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: #484850;
      border: 0.5px solid #484850;
      border-radius: 8px;
      overflow: hidden;
    }
    .cat-list li {
      background: #323236;
      padding: 10px 6px;
      align-items: center;
      text-align: center;
      gap: 2px;
    }
    .cat-list a {
      font-size: 0.9em;
      font-weight: 500;
      color: #e8e8ec;
    }
    .cat-sub {
      font-size: 10px;
    }

    /* social: centered, larger touch targets */
    .social-row {
      justify-content: center;
      gap: 0.9em;
      margin-bottom: 1em;
    }
    .social-btn {
      width: 40px;
      height: 40px;
    }

    /* re-order: social → categories → bottom */
    .footer-flex {
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    /* show Posts/Thoughts/Hobby/About on mobile */
    .footer-bottom {
      padding: 14px 20px 20px;
      flex-direction: column-reverse;
      align-items: center;
      gap: 8px;
      border-top: 0.5px solid #484850;
    }

    .footer-nav {
      display: flex;
    }
    .footer-copy {
      font-size: 11px;
    }
  }
</style>
