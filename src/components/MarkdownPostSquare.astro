---
import { Image } from "astro:assets";
import { convert } from "@/libs/date";
import { sectionMap } from "@/scripts/section";

const { post, isDisplaySection = true, isDisplayCategory = true } = Astro.props;

const section: keyof typeof sectionMap = post.filePath?.split("/").slice(1, -1)[0];
---

<section>
  {
    isDisplaySection && (
      <div class="post-section">
        <a href={sectionMap[section].url}>{sectionMap[section].title}</a>
      </div>
    )
  }
  {
    isDisplayCategory && (
      <div class="post-category">
        {
          post.data.category.map((each: string, index: number) => (
            <a
              href={
                sectionMap.categories.url +
                "/" +
                post.data.category
                  .map((each: string) => each.toLowerCase().replace(",", "").replace(" ", "-"))
                  .slice(0, index + 1)
                  .join("/")
              }
            >
              {each}
            </a>
          ))
        }
      </div>
    )
  }
  <div class="post-headline">
    <a href={`/posts/${post.filePath?.split("/").slice(1, -1).join("/")}`}>{post.data.title}</a>
  </div>
  <div class="post-deck">{post.data.deck}</div>
  <div class="post-time">
    <time class="post-created-time" datetime={post.data.created.toISOString()}>
      {convert(post.data.created).date}
    </time>
  </div>
</section>

<style>
  a {
    color: inherit;
    transition: all 0.2s ease;
  }

  a:hover {
    color: var(--text-link);
  }

  .post-image {
    margin-top: 1.4em;
  }

  .post-section {
    letter-spacing: 0.03em;
    font-size: 1em;
    color: var(--text-link);
    /* font-size: 0.8em; */
    /* text-transform: uppercase; */
  }

  .post-category {
    letter-spacing: 0.03em;
    font-size: 0.8em;
    text-transform: uppercase;
    font-weight: 500;

    a:not(:last-child)::after {
      content: " / ";
    }
  }

  .num-link:hover:not(.active) {
    background-color: var(--text-link-background);
  }

  .post-headline {
    margin: 0;
    padding: 0;
    line-height: 1.25em;
    font-size: 1.25em;
    font-weight: 500;

    @media only screen and (max-width: 700px) {
      font-size: 1.1em;
    }
  }

  .post-deck {
    margin: 0.5em 0 0;
    line-height: 1.4;
    font-size: 0.8em;
    /* tl-desc > 메인페이지의 최우측 Thoughs 내 텍스트 사이즈와 유사하게 맞추자 */
    /* font-size: 0.75em; */
    /* line-height: 1.4; */

    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 7;
    overflow: hidden;
    text-overflow: ellipsis;

    @media only screen and (max-width: 700px) {
      font-size: 0.75em;
    }
  }

  .post-time {
    margin-top: 0.4em;
    color: var(--text-auxiliary);
    letter-spacing: 0.02em;
    font-size: 0.75em;
    font-weight: 300;
  }
</style>
