---
import { Icon } from "astro-icon/components";
---

<rss-icon-button>
  <Icon name="lucide:rss" id="rss-link" />
</rss-icon-button>

<script>
  import { useTranslations, type Lang } from "@/scripts/i18n";

  class RssIconButton extends HTMLElement {
    connectedCallback() {
      const btn = this.querySelector("#rss-link");
      const lang = window.location.pathname.split("/")[1];
      const t = useTranslations(lang as Lang);

      btn?.addEventListener("click", () => {
        const rssUrl = `${window.location.origin}/${lang}/rss.xml`;
        // 클립보드 복사
        navigator.clipboard
          .writeText(rssUrl)
          .then(() => {
            triggerToast(t("rss.copied"));
          })
          .catch(() => {
            // 실패 시 대비책으로 주소창 이동
            window.location.href = rssUrl;
          });
      });
    }
  }
  customElements.define("rss-icon-button", RssIconButton);
</script>

<style>
  #rss-link {
    cursor: pointer;
    display: flex;
    align-items: center; /* 수직 중앙 정렬 */
  }
</style>
