---

---

<div class="markdown-content">
  <slot />
</div>

<style>
  .markdown-content {
    line-height: 1.76em;
    font-size: 1em;

    @media only screen and (max-width: 700px) {
      font-size: 0.84em;
    }

    a:hover {
      background-color: var(--text-link-background);
    }

    p {
      margin: 0.7em 0;
    }

    h1 {
      scroll-margin-top: 3.8em;
      font-size: 1.6em;
      font-weight: 500;
      margin: 1em 0 0.7em;
      @media only screen and (max-width: 700px) {
        font-size: 1.3em;
      }
    }

    h2 {
      scroll-margin-top: 4.4em;
      font-size: 1.3em;
      font-weight: 500;
      margin: 1em 0 0.7em;
      @media only screen and (max-width: 700px) {
        font-size: 1.2em;
      }
    }

    h3 {
      scroll-margin-top: 4.7em;
      font-size: 1.2em;
      font-weight: 500;
      margin: 1em 0 0.7em;
      @media only screen and (max-width: 700px) {
        font-size: 1.1em;
      }
    }

    h4 {
      /* scroll-margin-top: 4em; H4 부터는 #URL 이동 지원하지 않음 */
      font-size: 1.1em;
      font-weight: 500;
      margin: 1em 0 0.7em;
      @media only screen and (max-width: 700px) {
        font-size: 1em;
      }
    }

    h5 {
      /* scroll-margin-top: 4em; H4 부터는 #URL 이동 지원하지 않음 */
      font-size: 1em;
      font-weight: 500;
      margin: 1em 0 0.7em;
      @media only screen and (max-width: 700px) {
        font-size: 0.967em;
      }
    }

    hr {
      position: relative;
      margin: 1.8em auto;
      padding: 0;
      border: none;
      width: 78%;
      height: 1px;

      &::after {
        content: " ";
        position: absolute;
        top: 0;
        width: 100%;
        height: 1px;
        background-color: color-mix(in srgb, var(--text), transparent 50%);
      }
    }
  }
</style>
