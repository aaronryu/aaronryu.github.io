---
import SectionHeader from "@/components/SectionHeader.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import type { InferEntrySchema } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { getCollection, render } from "astro:content";

const thoughts = await getCollection("thoughts");
const descendingThoughts = thoughts
  .sort(
    (thought1, thought2) =>
      new Date(thought2.data.created).getTime() - new Date(thought1.data.created).getTime(),
  )
  .map((thought: CollectionEntry<"thoughts">) => thought.data);

// { 2026: { 4: [thought1, thought2], ... }, ... }
interface GroupedThoughts {
  [year: number]: {
    [month: number]: Array<InferEntrySchema<"thoughts">>;
  };
}

const grouped = groupByYearAndMonth(descendingThoughts);
function groupByYearAndMonth(thoughts: Array<InferEntrySchema<"thoughts">>) {
  return thoughts.reduce<GroupedThoughts>((acc, thought) => {
    const date = new Date(thought.created);
    const year = date.getFullYear();
    const month = date.getMonth() + 1;

    if (!acc[year]) acc[year] = {};
    if (!acc[year][month]) acc[year][month] = [];

    acc[year][month].push(thought);
    return acc;
  }, {});
}

// (A) 년 내림차순 정렬
const sortedYears = Object.keys(grouped)
  .map(Number)
  .sort((a, b) => b - a);

// 전체 아이템 인덱스 — 좌우 교차용
let itemIndex = 0;
---

<BaseLayout>
  <SectionHeader section={"thoughts"} />
  <main>
    <div class="tl-wrap">
      <div class="tl-fade-top"></div>
      <div class="tl-fade-bottom"></div>
      <div class="tl-center-line"></div>
      <div class="tl-scroll" id="tlScroll">
        {
          sortedYears.map((year) => {
            const months = grouped[year];

            // (B) 월 내림차순 정렬
            const sortedMonths = Object.keys(months)
              .map(Number)
              .sort((a, b) => b - a);

            return (
              <>
                {/* 연도 구분 마커 */}
                <div class="tl-year-marker">
                  <span class="tl-year-label">{year}</span>
                </div>

                {sortedMonths.map((month) => {
                  const items = months[month];

                  return items.map((thought) => {
                    const side = itemIndex++ % 2 === 0 ? "left" : "right";
                    const dateLabel = `${year}.${String(month).padStart(2, "0")}`;
                    const fullDate = new Date(thought.created).toLocaleDateString("ko-KR", {
                      year: "numeric",
                      month: "long",
                      day: "numeric",
                    });

                    return (
                      <div class={`tl-item ${side}`}>
                        {/* left면 콘텐츠 먼저, right면 빈칸 먼저 */}
                        {side === "left" ? (
                          <div class="tl-content">
                            <div class="tl-date">{fullDate}</div>
                            <div class="tl-title">{thought.title}</div>
                            <div class="tl-desc">{thought.description}</div>
                          </div>
                        ) : (
                          <div class="tl-empty" />
                        )}

                        {/* 가운데 dot */}
                        <div class="tl-dot-wrap">
                          <div class="tl-dot" />
                          <div class="tl-year-badge">{dateLabel}</div>
                        </div>

                        {/* right면 콘텐츠, left면 빈칸 */}
                        {side === "right" ? (
                          <div class="tl-content">
                            <div class="tl-date">{fullDate}</div>
                            <div class="tl-title">{thought.title}</div>
                            <div class="tl-desc">{thought.description}</div>
                          </div>
                        ) : (
                          <div class="tl-empty" />
                        )}
                      </div>
                    );
                  });
                })}
              </>
            );
          })
        }
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  main {
    max-width: 800px;
    margin: 0 auto;

    @media only screen and (max-width: 1280px) {
      padding: 0 1.2rem;
    }
  }
  .tl-wrap {
    position: relative;
    height: 480px;
    overflow: hidden;
    display: flex;
    justify-content: center;
  }
  .tl-scroll {
    overflow-y: scroll;
    height: 100%;
    width: 100%;
    scrollbar-width: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 2em 0 4em 0;
    @media only screen and (max-width: 700px) {
      padding: 1em 0 3em 0;
    }
    box-sizing: border-box;
    position: relative;
  }
  .tl-scroll::-webkit-scrollbar {
    display: none;
  }
  .tl-center-line {
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 0.5px;
    background: var(--text);
    transform: translateX(-50%);
  }
  /*  */
  .tl-dot-wrap {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }
  .tl-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    /* 앞 요소의 실제 배경은 연하게 */
    background-color: var(--text-link-background);
    /* 뒷 요소가 보이지 않게 처리 */
    backdrop-filter: blur(5px) brightness(1.2);
    border: 1px solid var(--text-link);
    flex-shrink: 0;
  }
  .tl-year-badge {
    font-size: 0.5em;
    font-weight: 400;
    color: var(--text);
    /* 앞 요소의 실제 배경은 연하게 */
    background-color: var(--text-link-background);
    /* 뒷 요소가 보이지 않게 처리 */
    backdrop-filter: blur(5px) brightness(1.2);
    border: 0.5px solid var(--text-link);
    border-radius: 20px;
    padding: 0px 6px;
    white-space: nowrap;
  }
  /* Content Type 1: 글 표기 */
  .tl-item {
    position: relative;
    display: flex;
    align-items: center;
    width: 100%;
    /* max-width: 560px; */
    max-width: 800px;
    min-height: 60px;
    margin: 0.4em 0;
  }
  .tl-item.left {
    flex-direction: row-reverse;
  }
  .tl-item.left .tl-content {
    margin-left: auto;
    /* margin-right: 0.4em; */
    text-align: right;
  }
  .tl-item.right {
    flex-direction: row;
  }
  .tl-item.right .tl-content {
    /* margin-left: 0.4em; */
    text-align: left;
  }
  /* Content Type 1 > 내부에 (오른쪽 / 왼쪽)으로 쏠린 글 */
  .tl-content {
    max-width: calc(50% - 2.4em);
    padding: 0.52em 0.7em 0.6em 0.7em;
    /* background: var(--color-background-secondary); */
    border: 1px solid var(--text-auxiliary);
    /* border-radius: 1em; */
    border-radius: 0.8em;
  }
  /* Content Type 1 > 내부에 (오른쪽 / 왼쪽)으로 쏠린 글 > 내부에 들어간 내용들 */
  .tl-date {
    font-size: 0.6em;
    color: var(--text-auxiliary);
    margin-bottom: 0.2em;
  }
  .tl-title {
    font-size: 0.8em;
    font-weight: 500;
    margin-bottom: 3px;
  }
  .tl-desc {
    font-size: 0.75em;
    line-height: 1.4;
  }
  /* Content Type 0: 연도 표기 */
  .tl-year-marker {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    /* max-width: 560px; */
    max-width: 800px;
    margin: 16px 0;
  }
  .tl-year-label {
    /* 앞 요소의 실제 배경은 연하게 */
    background-color: var(--bg);
    /* 뒷 요소가 보이지 않게 처리 */
    backdrop-filter: blur(5px) brightness(1.2);
    border: 1px solid var(--text-auxiliary);
    border-radius: 1.2em;
    padding: 0.1em 0.9em;
    font-size: 1em;
    font-weight: 500;
  }
  .tl-hint {
    text-align: center;
    font-size: 12px;
    color: var(--color-text-tertiary);
    margin-top: 8px;
  }
  .tl-fade-top,
  .tl-fade-bottom {
    position: absolute;
    left: 0;
    right: 0;
    height: 4em;
    @media only screen and (max-width: 700px) {
      height: 3em;
    }
    z-index: 10;
    pointer-events: none;
  }
  .tl-fade-top {
    top: 0;
    background: linear-gradient(to bottom, var(--bg) 30%, transparent);
  }
  .tl-fade-bottom {
    bottom: 0;
    background: linear-gradient(to top, var(--bg) 30%, transparent);
  }
</style>
