---
import Greeting from "@/components/Greetings";
import SectionHeader from "@/components/SectionHeader.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

const posts = await getCollection("blog");
const recentPosts = posts.map((post) => {
  const relatedPosts = posts
    // 생성날짜 기준 최신순으로 정렬
    .sort(
      (relatedPost1, relatedPost2) =>
        new Date(relatedPost2.data.created).getTime() -
        new Date(relatedPost1.data.created).getTime(),
    )
    // 원하는 개수(4개 또는 6개)만큼 자르기
    .slice(0, 6);
  return {
    params: { path: `${post.filePath?.split("/").slice(1, -1).join("/")}` },
    props: { post, relatedPosts },
  };
});

const pageTitle = "Home Page";
---

<BaseLayout pageTitle={pageTitle}>
  <SectionHeader section={"thoughts"} />
  <main>
    <div class="tl-wrap">
      <div class="tl-fade-top"></div>
      <div class="tl-fade-bottom"></div>
      <div class="tl-center-line"></div>
      <div class="tl-scroll" id="tlScroll">
        <div class="tl-year-marker">
          <span class="tl-year-label">2021</span>
        </div>
        <div class="tl-item right">
          <div class="tl-dot-wrap">
            <div class="tl-dot"></div>
            <div class="tl-year-badge">2021.07</div>
          </div>
          <div class="tl-content">
            <div class="tl-date">2021년 7월 5일</div>
            <div class="tl-title">베타 버전 출시</div>
