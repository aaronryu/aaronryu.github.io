---
import BaseLayout from "@/layouts/BaseLayout.astro";
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import { sectionMap } from "@/scripts/section.ts";
import { shuffle } from "@/scripts/shuffle.js";
import MarkdownPostSummary from "@/components/MarkdownPostSummary.astro";
import MarkdownPostSquare from "@/components/MarkdownPostSquare.astro";

const thoughts = await getCollection("thoughts");
const descendingThoughts = thoughts
  .sort(
    (thought1, thought2) =>
      new Date(thought2.data.created).getTime() - new Date(thought1.data.created).getTime(),
  )
  .map((thought: CollectionEntry<"thoughts">) => thought.data)
  .slice(0, 10);

const posts = await getCollection("blog");
const recentPosts = posts.sort(
  (relatedPost1, relatedPost2) =>
    new Date(relatedPost2.data.created).getTime() - new Date(relatedPost1.data.created).getTime(),
);

const recentPickedPosts = recentPosts.slice(0, 10);
const randomPickedSections = shuffle([...Object.keys(sectionMap)]).slice(0, 3);
const section1Post = recentPosts.filter(
  (post) => randomPickedSections[0] === post.filePath?.split("/").slice(1, -1)[0],
);
const section2Post = recentPosts.filter(
  (post) => randomPickedSections[1] === post.filePath?.split("/").slice(1, -1)[0],
);
const section3Post = recentPosts.filter(
  (post) => randomPickedSections[2] === post.filePath?.split("/").slice(1, -1)[0],
);
---

<BaseLayout>
  <main>
    <div class="dashboard">
      <div class="section-articles">
        <div class="random-articles">
          <MarkdownPostSquare post={recentPickedPosts[3]} />
          <MarkdownPostSquare post={recentPickedPosts[4]} />
          <MarkdownPostSquare post={recentPickedPosts[5]} />
          <MarkdownPostSquare post={recentPickedPosts[6]} />
        </div>
        <div class="recent-articles">
          <div class="recent-articles-headline">
            <MarkdownPostSummary post={recentPickedPosts[0]} />
          </div>
          <div class="recent-articles-middle">
            <div class="recent-middle-article">
              <MarkdownPostSquare post={recentPickedPosts[1]} />
            </div>
            <div class="recent-middle-article">
              <MarkdownPostSquare post={recentPickedPosts[2]} />
            </div>
          </div>
          <div class="recent-articles-list">
            <MarkdownPostSummary post={recentPickedPosts[3]} />
            <MarkdownPostSummary post={recentPickedPosts[4]} />
          </div>
          <a class="retrieve-more-button" href={sectionMap.posts.url}>더 많은 글들 보기</a>
        </div>
      </div>
      <div class="section-thoughts">
        <a href={sectionMap.thoughts.url}><div class="title">{sectionMap.thoughts.title}</div></a>
        <div class="description">문득 드는 짧은 생각들에 대한 메모</div>
        <div class="thoughts">
          {
            descendingThoughts.map((thought) => {
              const fullDate = new Date(thought.created).toLocaleDateString("ko-KR", {
                year: "numeric",
                month: "long",
                day: "numeric",
              });
              return (
                <div class="tl-content">
                  <div class="tl-title">{thought.title}</div>
                  <div class="tl-desc">{thought.description}</div>
                  <div class="tl-date">{fullDate}</div>
                </div>
              );
            })
          }
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  main {
    margin: 0 auto;

    @media only screen and (min-width: 700px) {
      max-width: 700px;
    }

    @media only screen and (min-width: 980px) {
      max-width: 980px;
    }

    @media only screen and (min-width: 1300px) {
      max-width: 1300px;
    }
  }

  .dashboard {
    display: grid;
    margin-top: 0.6em;
    margin-inline: 1.2em;
    margin-bottom: 1.8em;

    grid-template-columns: 1fr;

    @media only screen and (min-width: 980px) {
      grid-template-columns: minman(auto, 960px);
      grid-column-gap: 20px;
    }

    @media only screen and (min-width: 1300px) {
      grid-template-columns: 1fr 240px;
      grid-column-gap: 32px;
    }
  }

  .section-articles {
    display: grid;

    grid-template-columns: 1fr;

    @media only screen and (min-width: 980px) {
      grid-template-columns: 280px 1fr;
      grid-column-gap: 20px;
    }

    @media only screen and (min-width: 1300px) {
      grid-template-columns: 300px 1fr;
      grid-column-gap: 32px;
    }
  }

  .section-thoughts {
    display: none;

    .title {
      font-size: 1.3em;
      line-height: 1.2em;
    }
    .description {
      font-size: 0.85em;
      color: var(--text-auxiliary);
    }
    .thoughts {
      display: flex;
      flex-direction: column;
      /* gap: 0.5em; */
    }
    .tl-content {
      margin-top: 0.5em;
      /* margin-bottom: 0.5em; */
      padding: 0.52em 0.7em 0.6em 0.7em;
      /* background: var(--color-background-secondary); */
      /* border-radius: 1em; */
      /* border-radius: 0.8em; */
      border-left: 0.5px solid var(--text);
    }
    .tl-date {
      font-size: 0.6em;
      color: var(--text-auxiliary);
      margin-top: 0.2em;
    }
    .tl-title {
      font-size: 0.8em;
      font-weight: 500;
      margin-bottom: 3px;
    }
    .tl-desc {
      font-size: 0.75em;
      line-height: 1.4;
    }
  }

  /* 화면이 커지면(PC) 나타남 */
  @media (min-width: 1300px) {
    .section-thoughts {
      display: block;
    }
  }

  .random-articles {
    display: none;
  }

  /* 화면이 커지면(PC) 나타남 */
  @media (min-width: 980px) {
    .random-articles {
      display: flex;
      flex-direction: column;
      gap: 1.2em;
    }
  }

  .recent-articles {
    display: flex;
    flex-direction: column;
    gap: 1.2em;
  }

  .recent-articles-headline {
    display: flex;
    flex-direction: column;
    gap: 1.2em;
  }

  .recent-articles-middle {
    display: flex;
    flex-direction: row;
    gap: 1.2em;
  }

  .recent-middle-article {
    flex: 1;
  }

  .recent-articles-list {
    display: flex;
    flex-direction: column;
    gap: 1.2em;
  }

  .retrieve-more-button {
    /* cursor: pointer; */
    border-radius: 4px;
    background-color: var(--text-link-background);
    font-size: 1em;
    height: 2.6em;
    line-height: 2.6em;
    text-align: center;

    @media only screen and (max-width: 700px) {
      font-size: 0.84em;
    }
  }
</style>
