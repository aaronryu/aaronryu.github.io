---
import MarkdownPostSquare from "@/components/MarkdownPostSquare.astro";
import MarkdownPostSummary from "@/components/MarkdownPostSummary.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { sectionMap } from "@/scripts/section";
import type { GetStaticPaths, Page } from "astro";
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  // 1. /pages/ 로 시작하는 모든 섹션들에 대한 페이지네이션 적용
  const sections = Object.entries(sectionMap)
    .filter((each) => each[1].url.includes("/posts/"))
    .map((filtered) => filtered[0]);

  // 2. /pages/ 로 시작하는 모든 페이지 가져와
  const posts = await getCollection("blog");
  // For every section, return a `paginate()` result.
  // Make sure that you pass `{ params: { section }}` to `paginate()`
  // so that Astro knows which section grouping the result is for.

  // 3.
  return sections.flatMap((section) => {
    const filteredPosts = posts.filter(
      (post) => post.filePath?.split("/").slice(1, -1)[0] === section,
    );
    return paginate(filteredPosts, {
      params: { section },
      pageSize: 10,
    });
  });
};

interface Props {
  page: Page<CollectionEntry<"blog">>;
}

const { page } = Astro.props;
const params = Astro.params;
---

<BaseLayout>
  <!-- @ts-ignore -->
  <SectionHeader section={params.section} />
  <main>
    <div class="dashboard">
      {
        page.data.length === 0 && (
          <div class="non-articles">
            아직 작성된 글이 없습니다.
            <br />
            RSS 등록을 하신다면 새 글이 올라왔을때 볼 수 있어요!
            <br />
            [RSS 등록]
          </div>
        )
      }
      {
        page.data.length > 0 && (
          <div class="recent-articles">
            <div class="recent-articles-headline">
              <MarkdownPostSummary post={page.data[0]} isDisplaySection={false} />
            </div>
            {page.data.length >= 4 && (
              <div class="recent-articles-middle">
                <div class="recent-middle-article">
                  <MarkdownPostSquare post={page.data[1]} isDisplaySection={false} />
                </div>
                <div class="recent-middle-article">
                  <MarkdownPostSquare post={page.data[2]} isDisplaySection={false} />
                </div>
                <div class="recent-middle-article">
                  <MarkdownPostSquare post={page.data[3]} isDisplaySection={false} />
                </div>
              </div>
            )}
            <div class="recent-articles-list">
              {page.data.slice(page.data.length < 4 ? 1 : 4).map((each, index) => (
                <MarkdownPostSummary post={each} isDisplaySection={false} />
              ))}
            </div>
            <a class="retrieve-more-button" href={sectionMap.posts.url}>
              더 많은 글들 보기
            </a>
          </div>
        )
      }
    </div>
  </main>
</BaseLayout>

<style>
  .dashboard {
    max-width: 800px;
    margin: 0.6em auto 1.8em;
    padding: 0 1.2em;
    /* margin-top: 0.6em; */
    /* margin-inline: 1.2em; */
    /* margin-bottom: 1.8em; */
  }

  .recent-articles {
    display: flex;
    flex-direction: column;
    gap: 1.2em;
  }

  .recent-articles-headline {
    display: flex;
    flex-direction: column;
    gap: 1.2em;
  }

  .recent-articles-middle {
    display: flex;
    flex-direction: row;
    gap: 1.2em;
  }

  .recent-middle-article {
    flex: 1;
  }

  .recent-articles-list {
    display: flex;
    flex-direction: column;
    gap: 1.2em;
  }

  .retrieve-more-button {
    /* cursor: pointer; */
    border-radius: 4px;
    background-color: var(--text-link-background);
    font-size: 1em;
    height: 2.6em;
    line-height: 2.6em;
    text-align: center;

    @media only screen and (max-width: 700px) {
      font-size: 0.84em;
    }
  }
</style>
