---
import MarkdownPostSummary from "@/components/MarkdownPostSummary.astro";
import PaginationNavigator from "@/components/PaginationNavigator.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { sectionMap } from "@/scripts/section";
import type { GetStaticPaths, Page } from "astro";
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import RssRoundButton from "@/components/RssRoundButton.astro";
import { getI18nStaticPaths, useTranslatedPath, useTranslations, type Lang } from "@/scripts/i18n";

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  return getI18nStaticPaths(async (lang) => {
    // 1. /pages/ 로 시작하는 모든 섹션들에 대한 페이지네이션 적용
    const sections = Object.entries(sectionMap)
      .filter((each) => each[1].url.includes("/posts/"))
      .map((filtered) => filtered[0]);

    // 2. /pages/ 로 시작하는 모든 페이지 가져와
    const posts = await getCollection("blog", ({ id }) => id.includes(`/${lang}/`));
    // For every section, return a `paginate()` result.
    // Make sure that you pass `{ params: { section }}` to `paginate()`
    // so that Astro knows which section grouping the result is for.

    // 3. [section]/[...page] 자동 생성 < Astro 에서 자체적으로 제공하는 Pagination 사용 방법
    return sections.flatMap((section) => {
      const filteredPosts = posts
        .filter((post) => post.filePath?.split("/").slice(1, -1)[0] === section)
        .sort(
          (thought1, thought2) =>
            new Date(thought2.data.created).getTime() - new Date(thought1.data.created).getTime(),
        );

      return paginate(filteredPosts, {
        params: { lang, section },
        pageSize: 5,
      });
    });
  });
};

interface Props {
  page: Page<CollectionEntry<"blog">>;
}

interface Params {
  lang: Lang;
  section: keyof typeof sectionMap;
}

const { lang, section } = Astro.params as unknown as Params;
const translatePath = useTranslatedPath(lang!);
const t = useTranslations(lang as Lang);

const { page } = Astro.props as unknown as Props;
---

<BaseLayout
  lang={lang}
  title={sectionMap[section].title}
  keywords={sectionMap[section].shorten[lang]}
  description={sectionMap[section].description[lang]}
>
  <!-- @ts-ignore -->
  <SectionHeader lang={lang} section={section} />
  <main>
    <div class="dashboard">
      {
        page.data.length === 0 && (
          <div class="non-articles">
            <span class="line-1">{t("post.not-exists")}</span>
            <span class="line-2">{t("post.rss-guidance")}</span>
            <RssRoundButton />
          </div>
        )
      }
      {
        page.data.length > 0 && (
          <div class="recent-articles">
            <div class="recent-articles-list">
              {page.data.map((each, index) => (
                <MarkdownPostSummary
                  lang={lang as Lang}
                  post={each}
                  isDisplaySection={false}
                  isDisplayCategory={section !== "opinion"}
                  isDisplayImage={false}
                />
              ))}
            </div>
            {/* @ts-ignore */}
            <PaginationNavigator baseurl={translatePath(sectionMap[section].url)} page={page} />
          </div>
        )
      }
    </div>
  </main>
</BaseLayout>

<style>
  .dashboard {
    max-width: 700px;
    margin: 1.2em auto 2.6em;
    padding: 0 1.2em;
  }

  .non-articles {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    line-height: 1.2em;

    .line-1 {
      font-size: 0.8em;
    }

    .line-2 {
      font-size: 1em;
    }
  }

  .recent-articles {
    display: flex;
    flex-direction: column;
    gap: 1.2em;
  }

  .recent-articles-headline {
    display: flex;
    flex-direction: column;
    gap: 1.2em;
  }

  .recent-articles-middle {
    display: flex;
    flex-direction: row;
    gap: 1.2em;
  }

  .recent-middle-article {
    flex: 1;
  }

  .recent-articles-list {
    display: flex;
    flex-direction: column;
    gap: 1.2em;
  }
</style>
