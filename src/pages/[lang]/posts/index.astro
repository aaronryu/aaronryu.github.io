---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { sectionMap } from "@/scripts/section";
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import MarkdownPostSummary from "@/components/MarkdownPostSummary.astro";
import MarkdownPostSquare from "@/components/MarkdownPostSquare.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import { SUPPORTED_LANGUAGES, useTranslatedPath } from "@/scripts/i18n";

export async function getStaticPaths() {
  return SUPPORTED_LANGUAGES.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const translatePath = useTranslatedPath(lang);

// 1. /pages/ 로 시작하는 모든 섹션들만 거른 뒤
const sections = Object.entries(sectionMap)
  .filter((each) => each[1].url.includes("/posts/"))
  .map((filtered) => filtered[0]);

// 2. /pages/ 로 시작하는 모든 페이지 가져와 Map (key: Section 명, value: 해당 Section 내 Post 리스트)
const posts = await getCollection("blog", ({ id }) => id.includes(`/${lang}/`));
const sectionPosts = new Map(
  sections.map((section) => {
    const filteredPosts = posts
      .filter((post) => post.filePath?.split("/").slice(1, -1)[0] === section)
      .sort(
        (thought1, thought2) =>
          new Date(thought2.data.created).getTime() - new Date(thought1.data.created).getTime(),
      )
      .slice(0, 4);

    return [section, filteredPosts];
  }),
);
---

<BaseLayout lang={lang}>
  <main>
    <SectionHeader section={"posts"} />
    <div class="dashboard">
      {
        sectionPosts
          .entries()
          .filter((each) => {
            const section = each[0];
            const posts = each[1];

            return posts.length !== 0;
          })
          .map((each) => {
            const section = each[0];
            const posts = each[1];

            return (
              <div class="recent-articles">
                {/* @ts-ignore */}
                <a href={translatePath(sectionMap[section].url)}>
                  <div class="section-header">
                    <div class="section-header-title">
                      {/* @ts-ignore */}
                      {sectionMap[section].title} {sectionMap[section].shorten}
                    </div>
                    <div class="section-header-button">View All</div>
                  </div>
                </a>
                <div class="recent-articles-list">
                  {posts.length === 1 &&
                    posts.map((each: CollectionEntry<"blog">, index: number) => (
                      <MarkdownPostSummary
                        lang={lang}
                        post={each}
                        isDisplaySection={false}
                        isDisplayCategory={section !== "opinion"}
                        isDisplayImage={false}
                      />
                    ))}
                  {posts.length >= 2 &&
                    posts.map((each: CollectionEntry<"blog">, index: number) => (
                      <div class="recent-middle-article">
                        <MarkdownPostSquare
                          lang={lang}
                          post={each}
                          isDisplaySection={false}
                          isDisplayCategory={section !== "opinion"}
                          isDisplayImage={false}
                        />
                      </div>
                    ))}
                </div>
              </div>
            );
          })
      }
    </div>
  </main>
</BaseLayout>

<style>
  .dashboard {
    max-width: 800px;
    margin: 1.2em auto 2.6em;
    padding: 0 1.2em;
  }

  .recent-articles {
    display: flex;
    flex-direction: column;
    gap: 0.6em;

    border-top: 1px solid var(--text);
    margin-bottom: 1em;
  }

  .section-header {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    margin-top: 0.6em;
    padding-inline: 0.3em;
    border-radius: 0.1em;
    font-weight: 500;
    transition: all 0.2s ease;

    .section-header-title {
      font-size: 1.2em;
    }

    .section-header-button {
      color: var(--text);
    }
  }

  .section-header:hover {
    background-color: var(--text-link-background);
  }

  /* 3번째 요소부터(두 번째 줄) 윗부분에 구분선 추가 */
  .recent-middle-article:nth-child(n + 3) {
    border-top: 1px solid var(--text-placeholder);
    padding-top: 1em;
  }

  .recent-articles-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.2em;
    padding-inline: 0.3em;
  }
</style>
